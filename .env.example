# =============================================================================
# ModelSentinel Configuration Template
# Copy this to .env and fill in your values for deployment
# =============================================================================

# JWT Authentication Secret
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CRITICAL: Set a strong random value in production
JWT_SECRET_KEY=your_long_random_secret_key_minimum_32_characters_here

# Groq API (for threat report generation)
# Get key from: https://console.groq.com/keys
# CRITICAL: Required for production report generation
GROQ_API_KEY=gsk_your_groq_api_key_here

# Frontend Configuration
# Set to your Streamlit frontend URL in production
FRONTEND_URL=http://localhost:8501

# API Configuration
# URL where the API will be accessible
SENTINEL_API_URL=http://localhost:8000

# Database Configuration
# SQLite database file path
DB_PATH=src/data/scans.db

# Optional: GPU Acceleration
# Set to true if you have CUDA-capable GPU
USE_GPU=false
DEVICE=cpu

# Optional: Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Environment
# Development or production
ENVIRONMENT=development

# Optional: Max File Size (MB)
# Maximum model file size to accept for scanning
MAX_FILE_SIZE_MB=2048

# Optional: Database Backup
# Enable automatic backups to S3 (requires AWS credentials)
BACKUP_ENABLED=false
AWS_BACKUP_BUCKET=modelsentinel-backups
JWT_SECRET_KEY=make_up_any_long_random_string_here
FRONTEND_URL=http://localhost:8501